{
  "name": "@agent-major/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-major": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "data:init": "tsx src/data-init.ts",
    "phase11:demo": "tsx src/phase11.ts demo",
    "phase11:round": "tsx src/phase11.ts round",
    "phase11:replay": "tsx src/phase11.ts replay",
    "phase11:export": "tsx src/phase11.ts export",
    "phase12:map": "tsx src/phase12.ts map",
    "phase12:replay": "tsx src/phase12.ts replay",
    "phase12:export": "tsx src/phase12.ts export"
  },
  "dependencies": {
    "@agent-major/core": "workspace:*",
    "@agent-major/db": "workspace:*",
    "@agent-major/llm": "workspace:*",
    "@agent-major/queue": "workspace:*"
  }
}
