{
  "asset_id": "map_dust2_node_graph_v1",
  "map_slug": "dust2",
  "display_name": "Dust2",
  "phase_scope": "phase_2_0_pre",
  "purpose": "为节点化回合引擎提供 Dust2 重要位置、连接关系、路线关系和商业语义锚点，避免 LLM 自行猜测地图拓扑。",
  "graph_model": {
    "node_semantics": "节点是状态容器，不只是区名。节点可记录人数、控制权、可见信息、道具影响、商业计划意图、交火前后状态。",
    "edge_semantics": "边表示常规可达或可交火连接，不表示每次行动必然成功。",
    "activation_rule": "每回合只激活 3-5 个关键节点及其相邻节点；未激活节点保持轻量状态。"
  },
  "timing_model": {
    "unit": "abstract_phase_step",
    "principle": "本模型不追求精确秒表跑图，但必须约束每个时间点的最远可达节点，避免 LLM 写出默认阶段 T 已经到达包点等不合理事实。",
    "round_phases": [
      {
        "id": "default_opening",
        "display_name": "默认展开",
        "phase_index": 1,
        "meaning": "开局站位、默认控图、经济买型、商业计划开局部署。"
      },
      {
        "id": "first_contact",
        "display_name": "第一接触",
        "phase_index": 2,
        "meaning": "A 大、中路、B 洞等前沿区域发生信息交换或首次交火。"
      },
      {
        "id": "mid_round_decision",
        "display_name": "中盘决策",
        "phase_index": 3,
        "meaning": "转点、夹击、重新集合、资源再分配。"
      },
      {
        "id": "execute_or_retake",
        "display_name": "进点 / 回防",
        "phase_index": 4,
        "meaning": "进攻方进入包点或防守方开始回防。"
      },
      {
        "id": "post_plant_or_clutch",
        "display_name": "守包 / 拆包 / 残局",
        "phase_index": 5,
        "meaning": "下包后守包、拆包、残局、保枪或最终全歼。"
      }
    ],
    "edge_cost_by_type": {
      "local": 0.25,
      "site": 0.35,
      "route": 0.75,
      "transition": 0.9,
      "retake": 0.9,
      "choke": 1,
      "contact": 1,
      "risky_route": 0.8,
      "risky_contact": 1
    },
    "hard_constraints": [
      "default_opening 阶段 T 方不能声称已经到达 A 默认包位、B 默认包位或完成下包。",
      "default_opening 阶段 CT 方可以已经在 A 点、B 点、中门、A 小、B 门、B 窗等防守位置建立默认站位。",
      "T 方进入包点通常不得早于 execute_or_retake；如果是快攻，最早也应通过 first_contact 或 mid_round_decision 中的前沿接触节点。",
      "下包、拆包、守包和包炸只能发生在 execute_or_retake 或 post_plant_or_clutch 阶段。",
      "跨越不相邻节点必须经过 node graph 中的中间节点，不能直接瞬移。"
    ],
