{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@agent-major/shared": ["packages/shared/src/index.ts"],
      "@agent-major/llm": ["packages/llm/src/index.ts"],
      "@agent-major/queue": ["packages/queue/src/index.ts"],
      "@agent-major/db": ["packages/db/src/index.ts"],
      "@agent-major/core": ["packages/core/src/index.ts"],
      "@agent-major/cli": ["packages/cli/src/index.ts"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "verbatimModuleSyntax": true
  }
}
